{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/login.html"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://trackshopee-admin.onrender.com/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://trackshopee-admin.onrender.com/api/:path*"
    },
    {
      "source": "/shopee/:path*",
      "destination": "https://trackshopee-admin.onrender.com/shopee/:path*"
    },
    {
      "source": "/autopee-api/:path*",
      "destination": "https://trackshopee-admin.onrender.com/autopee-api/:path*"
    },
    {
      "source": "/mail-api/:path*",
      "destination": "https://trackshopee-admin.onrender.com/mail-api/:path*"
    },
    {
      "source": "/otistx-api/:path*",
      "destination": "https://trackshopee-admin.onrender.com/otistx-api/:path*"
    }
  ]
}